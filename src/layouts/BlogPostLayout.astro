---
import BaseLayout from "./BaseLayout.astro";
import BlogCover from "../components/BlogCover.astro";

const { frontmatter, category } = Astro.props;

const formatDate = (value: string | Date | undefined) => {
  if (!value) return undefined;

  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toDateString();
};

const formatCategory = (value: string) =>
  value
    .split(/[-_]/)
    .map((part: string) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const publishedDate = formatDate(frontmatter.publishedDate);
const updatedDate = formatDate(frontmatter.updatedDate);
---

<BaseLayout title={frontmatter.title} 
    description={frontmatter.description} 
    publishedDate={frontmatter.publishedDate}
    updatedDate={frontmatter.updatedDate}
    type="article">
  <article class="article-shell">
    <a href="/blog" class="article-link">
      <span aria-hidden="true">&lt;-</span>
      Back to blog
    </a>

    <header class="article-header">
      <div class="flex flex-wrap items-center gap-2">
        {
          category && (
            <span class="chip">{formatCategory(category)}</span>
          )
        }
        {
          frontmatter.tags?.map((tag: string) => (
            <span class="chip chip--neutral">#{tag}</span>
          ))
        }
      </div>

      <h1 class="page-title mt-6 max-w-4xl text-5xl text-slate-950 dark:text-white md:text-6xl">
        {frontmatter.title}
      </h1>

      <p class="page-copy max-w-3xl">
        {frontmatter.description}
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-[var(--color-text-muted)]">
        {publishedDate && <span>{publishedDate}</span>}
        {
          updatedDate && (
            <span>Updated: {updatedDate}</span>
          )
        }
      </div>

      {
        frontmatter.coverImage && (
          <div class="article-cover">
            <BlogCover
              src={frontmatter.coverImage}
              alt={frontmatter.coverAlt}
              priority={true}
            />
          </div>
        )
      }
    </header>

    <div class="article-prose">
      <slot />
    </div>

    <footer class="article-footer-nav">
      <a href="/blog" class="action-button action-button--tonal">
        <span aria-hidden="true">&lt;-</span>
        Back to blog
      </a>
      <a href="/rss.xml" class="blog-text-link">
        More writing via RSS
        <span aria-hidden="true">-></span>
      </a>
    </footer>
  </article>
</BaseLayout>
