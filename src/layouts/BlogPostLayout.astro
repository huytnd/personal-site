---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter, category } = Astro.props;

const formatDate = (value: string | Date | undefined) => {
  if (!value) return undefined;

  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toDateString();
};

const formatCategory = (value: string) =>
  value
    .split(/[-_]/)
    .map((part: string) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const publishedDate = formatDate(frontmatter.publishedDate);
const updatedDate = formatDate(frontmatter.updatedDate);
---

<BaseLayout title={frontmatter.title}>
  <article class="article-shell">
    <a href="/blog" class="article-link">
      ← Back to blog
    </a>

    <header class="article-header">
      <div class="flex flex-wrap items-center gap-2">
        {
          category && (
            <span class="chip">{formatCategory(category)}</span>
          )
        }
        {
          frontmatter.tags?.map((tag: string) => (
            <span class="chip chip--neutral">#{tag}</span>
          ))
        }
      </div>

      <h1 class="page-title text-4xl md:text-5xl">
        {frontmatter.title}
      </h1>

      <p class="page-copy max-w-2xl">
        {frontmatter.description}
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-[var(--color-text-muted)]">
        {publishedDate && <span>{publishedDate}</span>}
        {
          updatedDate && (
            <span>Updated: {updatedDate}</span>
          )
        }
      </div>
    </header>

    <div class="article-prose">
      <slot />
    </div>
  </article>
</BaseLayout>
