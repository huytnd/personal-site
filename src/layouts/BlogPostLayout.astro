---
import BaseLayout from "./BaseLayout.astro";
import BlogCover from "../components/BlogCover.astro";
import PostCard from "@/components/blog/PostCard.astro";
import TaxonomyPills from "@/components/blog/TaxonomyPills.astro";
import { formatBlogDate, getArchiveUrl, type BlogPost } from "@/lib/blog";

interface Props {
  frontmatter: BlogPost["data"];
  postUrl: string;
  relatedPosts?: BlogPost[];
}

const {
  frontmatter,
  postUrl,
  relatedPosts = [],
} = Astro.props as Props;

const publishedDate = formatBlogDate(frontmatter.publishedDate);
const updatedDate = frontmatter.updatedDate
  ? formatBlogDate(frontmatter.updatedDate)
  : undefined;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.coverImage?.src}
  publishedDate={frontmatter.publishedDate.toISOString()}
  updatedDate={frontmatter.updatedDate?.toISOString()}
  canonicalURL={frontmatter.canonicalUrl ?? postUrl}
  type="article"
>
  <article class="article-shell">
    <a href="/blog" class="article-link">
      <span aria-hidden="true">&lt;-</span>
      Back to blog
    </a>

    <header class="article-header">
      <TaxonomyPills category={frontmatter.category} tags={frontmatter.tags} />

      <h1 class="page-title mt-6 max-w-4xl text-5xl text-slate-950 dark:text-white md:text-6xl">
        {frontmatter.title}
      </h1>

      <p class="page-copy max-w-3xl">
        {frontmatter.description}
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-[var(--color-text-muted)]">
        {publishedDate && <span>{publishedDate}</span>}
      {
        updatedDate && (
          <span>Updated: {updatedDate}</span>
        )
      }
        {
          frontmatter.series && (
            <span>Series: {frontmatter.series}</span>
          )
        }
      </div>

      {
        frontmatter.coverImage && (
          <div class="article-cover">
            <BlogCover
              src={frontmatter.coverImage}
              alt={frontmatter.coverAlt}
              priority={true}
            />
          </div>
        )
      }
    </header>

    <div class="article-prose">
      <slot />
    </div>

    {
      relatedPosts.length > 0 && (
        <section class="article-related">
          <div class="mb-8">
            <p class="section-kicker">Related</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">
              Continue reading
            </h2>
          </div>

          <div class="blog-post-grid">
            {relatedPosts.map((post) => <PostCard post={post} />)}
          </div>
        </section>
      )
    }

    <footer class="article-footer-nav">
      <a href="/blog" class="action-button action-button--tonal">
        <span aria-hidden="true">&lt;-</span>
        Back to blog
      </a>
      <a href={getArchiveUrl()} class="blog-text-link">
        Browse the archive
        <span aria-hidden="true">-></span>
      </a>
    </footer>
  </article>
</BaseLayout>
