---
import "../styles/global.css";
import Header from "../components/Header.astro";

const { title } = Astro.props;
---

<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <div class="site-shell">
      <div class="site-shell__glow site-shell__glow--left"></div>
      <div class="site-shell__glow site-shell__glow--right"></div>

      <Header />

      <main class="mx-auto w-full max-w-7xl px-5 py-8 sm:px-6 lg:px-10 md:py-12">
        <div class="site-panel">
          <slot />
        </div>
      </main>

      <footer class="mx-auto w-full max-w-7xl px-5 pb-10 pt-2 text-center sm:px-6 lg:px-10">
        <div class="footer-panel">
          <p class="footer-copy">&copy; 2026 Huy Tran. All rights reserved.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
