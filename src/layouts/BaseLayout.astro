---
import "../styles/global.css";
import Header from "../components/Header.astro";
 
/* interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  publishedDate?: string;
  canonicalURL?: string;
} */

const { 
  title,
  description,
  image,
  type= "website",
  publishedDate,
  updatedDate,
  canonicalURL
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://huytnd.io.vn'
const canonical = canonicalURL ?? new URL(Astro.url.pathname, site).href;
const ogImage = image
  ? new URL(image, site).href 
  : new URL('/open-graph/og-image.png', site).href;

const jsonLd =
  type === 'article'
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      image: [ogImage],
      datePublished: publishedDate || new Date().toISOString(),
      dateModified: updatedDate ? updatedDate : publishedDate || new Date().toISOString(),
      author: {
        "@type": "Person",
        name: "Huy Tran"
      },
      mainEntityOfPage: canonical
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebPage",
      headline: title,
      description,
      url: canonical
    };
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="alternate" type="application/rss+xml" title="Huy Tran Blog RSS" href="/rss.xml" />
    <title>{title} - Huy Tran | Software Engineer</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-dark.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storedTheme = window.localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = storedTheme ? storedTheme === 'dark' : prefersDark;
        root.classList.toggle('dark', isDark);
        root.style.colorScheme = isDark ? 'dark' : 'light';
      })();
    </script>

    <style>
      :root {
        --accent-color: #0A2540;
      }
      .dark {
        --accent-color: #60A5FA;
      }
    </style>
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LCYQ4SKTG1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-LCYQ4SKTG1');
    </script>
  </head>

  <body class="bg-white dark:bg-[#0F172A] text-slate-900 dark:text-slate-100 transition-colors duration-300 font-sans">
    <!-- Navigation -->
    <Header />

    <!-- Main Content -->
    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 text-slate-400 py-12 mt-24">
      <div class="max-w-7xl mx-auto px-6 text-center text-sm">
        <p>© {new Date().getFullYear()} Huy Tran • Software Engineer</p>
        <p class="mt-2 text-xs text-slate-500">
          Built with Astro + Tailwind CSS + Three.js
        </p>
      </div>
    </footer>
  </body>
</html>
