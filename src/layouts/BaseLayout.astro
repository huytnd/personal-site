---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  publishedDate?: string;
  canonicalURL?: string;
}

const { 
  title,
  description,
  image = '/images/og-image.jpg',
  type= "website",
  publishedDate,
  canonicalURL
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://huytnd.io.vn'
const canonical = canonicalURL ?? new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="alternate" type="application/rss+xml" title="Huy Tran Blog RSS" href="/rss.xml" />
    <title>{title} - Huy Tran | Software Engineer</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        author: {
          "@type": "Person",
          name: "Huy Tran"
        },
        datePublished: publishedDate || new Date().toISOString(),
        mainEntityOfPage: canonical
      })}
    </script>

    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const storedTheme = window.localStorage.getItem(storageKey);
        const theme = storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : prefersDark
            ? "dark"
            : "light";

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LCYQ4SKTG1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-LCYQ4SKTG1');
    </script>
  </head>

  <body>
    <div class="site-shell">
      <div class="site-shell__glow site-shell__glow--left"></div>
      <div class="site-shell__glow site-shell__glow--right"></div>

      <Header />

      <main class="mx-auto w-full max-w-[96rem] px-6 py-10 sm:px-8 md:py-14 lg:px-12">
        <div class="site-panel">
          <slot />
        </div>
      </main>

      <footer class="mx-auto w-full max-w-[96rem] px-6 pb-10 pt-2 text-center sm:px-8 lg:px-12">
        <div class="footer-panel">
          <p class="footer-copy">&copy; {new Date().getFullYear()} Huy Tran. All rights reserved.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
