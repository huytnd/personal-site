---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="mx-auto w-full max-w-7xl px-5 pt-5 sm:px-6 lg:px-10 md:pt-7">
  <div class="header-shell">
    <a href="/" class="header-brand">
      <span class="header-brand__mark">HT</span>
      <span>
        <span class="block text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Portfolio</span>
        <span class="block text-lg font-semibold tracking-tight text-slate-950">Huy Tran</span>
      </span>
    </a>

    <nav class="hidden gap-2 md:flex">
      {
        navItems.map((item) => {
          const isActive = currentPath === item.href;
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition",
                isActive
                  ? "bg-slate-900 text-white shadow-sm"
                  : "text-slate-600 hover:bg-white/70 hover:text-slate-950"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>

  <nav class="mt-3 md:hidden">
    <div class="header-mobile-nav">
      {
        navItems.map((item) => {
          const isActive = currentPath === item.href;
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition",
                isActive
                  ? "bg-slate-900 text-white shadow-sm"
                  : "bg-white/75 text-slate-600 hover:text-slate-950"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>
