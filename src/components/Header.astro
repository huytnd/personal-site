---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="mx-auto w-full max-w-[96rem] px-6 pt-5 sm:px-8 lg:px-12 md:pt-7">
  <div class="header-shell">
    <a href="/" class="header-brand">
      <span class="header-brand__mark">HT</span>
      <span>
        <span class="block text-lg font-semibold tracking-tight text-[var(--color-text)]">Huy Tran</span>
        <span class="mt-0.5 block text-xs uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Engineer</span>
      </span>
    </a>

    <div class="flex items-center gap-3">
      <nav class="hidden gap-2 md:flex" aria-label="Primary">
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href;
            return (
              <a
                href={item.href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "nav-pill",
                  isActive ? "nav-pill--active" : "nav-pill--idle"
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <button type="button" class="theme-toggle" data-theme-toggle aria-label="Switch color theme">
        <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
            <circle cx="12" cy="12" r="4.25" stroke="currentColor" stroke-width="1.8"></circle>
            <path d="M12 2.75v2.5M12 18.75v2.5M5.46 5.46l1.76 1.76M16.78 16.78l1.76 1.76M2.75 12h2.5M18.75 12h2.5M5.46 18.54l1.76-1.76M16.78 7.22l1.76-1.76" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
          </svg>
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
            <path d="M20 14.25A7.25 7.25 0 0 1 9.75 4c-.03.28-.05.57-.05.86a9.39 9.39 0 0 0 9.39 9.39c.31 0 .61-.02.91-.05Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8"></path>
          </svg>
        </span>
        <span class="theme-toggle__label">Dark</span>
      </button>
    </div>
  </div>

  <nav class="mt-3 md:hidden" aria-label="Primary mobile">
    <div class="header-mobile-nav">
      {
        navItems.map((item) => {
          const isActive = currentPath === item.href;
          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "nav-pill",
                isActive ? "nav-pill--active" : "nav-pill--idle"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const storageKey = "theme-preference";
    const root = document.documentElement;
    const toggle = document.querySelector("[data-theme-toggle]");

    if (!toggle) return;

    const label = toggle.querySelector(".theme-toggle__label");
    const getTheme = () => root.dataset.theme === "dark" ? "dark" : "light";

    const syncLabel = () => {
      const nextTheme = getTheme() === "dark" ? "Light" : "Dark";
      if (label) label.textContent = nextTheme;
      toggle.setAttribute("aria-label", `Switch to ${nextTheme.toLowerCase()} theme`);
      toggle.setAttribute("title", `Switch to ${nextTheme.toLowerCase()} theme`);
    };

    syncLabel();

    toggle.addEventListener("click", () => {
      const nextTheme = getTheme() === "dark" ? "light" : "dark";
      root.dataset.theme = nextTheme;
      root.style.colorScheme = nextTheme;
      window.localStorage.setItem(storageKey, nextTheme);
      syncLabel();
    });
  })();
</script>
