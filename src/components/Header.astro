---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
const logoText = "<ht/>";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-[#0F172A]/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 text-2xl font-bold tracking-tighter group">
      <span class="font-mono text-3xl text-[#0A2540] dark:text-[#60A5FA] transition group-hover:scale-110">{logoText}</span>
      <div>
        <span class="text-slate-900 dark:text-white">Huy Tran</span>
        <span class="block text-[10px] uppercase tracking-[0.125em] text-slate-500 dark:text-slate-400 -mt-1">Software Engineer</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || 
                        (item.href !== "/" && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`transition-colors duration-200 hover:text-[#0A2540] dark:hover:text-[#60A5FA]
                    ${isActive 
                      ? "text-[#0A2540] dark:text-[#60A5FA] font-semibold" 
                      : "text-slate-600 dark:text-slate-400"}`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button 
        id="theme-toggle"
        class="w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all active:scale-95"
        aria-label="Toggle dark mode">
        <span id="theme-icon" class="text-xl transition">☀️</span>
      </button>

      <!-- GitHub -->
      <a 
        href="https://github.com/huytnd" 
        target="_blank"
        rel="noreferrer"
        class="group inline-flex h-10 items-center gap-2 rounded-2xl border border-slate-200 bg-white/80 px-3 text-slate-700 transition hover:border-slate-300 hover:text-[#0A2540] dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
        aria-label="GitHub profile">
        <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-current" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.699-2.782.605-3.369-1.343-3.369-1.343-.455-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.071 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.091-.647.349-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.56 9.56 0 0 1 2.504.337c1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.202 2.398.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.921.678 1.857 0 1.339-.012 2.419-.012 2.748 0 .268.18.58.688.481A10.019 10.019 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z"></path>
        </svg>
        <span class="hidden text-sm font-medium lg:inline">GitHub</span>
      </a>

      <!-- LinkedIn -->
      <a 
        href="https://linkedin.com/in/huytnd" 
        target="_blank"
        rel="noreferrer"
        class="group inline-flex h-10 items-center gap-2 rounded-2xl border border-slate-200 bg-white/80 px-3 text-slate-700 transition hover:border-[#0A66C2] hover:text-[#0A66C2] dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200 dark:hover:border-[#60A5FA] dark:hover:text-[#60A5FA]"
        aria-label="LinkedIn profile">
        <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-current" aria-hidden="true">
          <path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19ZM8.339 10.339H5.667V18.333H8.339V10.339ZM7.003 6.071A1.55 1.55 0 0 0 5.45 7.625c0 .858.694 1.554 1.553 1.554h.018a1.554 1.554 0 1 0-.018-3.108ZM18.333 13.467c0-2.699-1.439-3.955-3.359-3.955-1.548 0-2.241.852-2.628 1.451v-1.624H9.675c.035 1.076 0 8.994 0 8.994h2.671V13.87c0-.238.017-.477.087-.648.188-.476.616-.969 1.336-.969.943 0 1.321.73 1.321 1.801v4.279h2.672l.001-4.866Z"></path>
        </svg>
        <span class="hidden text-sm font-medium lg:inline">LinkedIn</span>
      </a>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav class="md:hidden border-t border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-[#0F172A]/80 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-6 py-3 flex gap-2 overflow-x-auto">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || 
                        (item.href !== "/" && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`px-5 py-2 text-sm font-medium rounded-2xl whitespace-nowrap transition
                    ${isActive 
                      ? "bg-[#0A2540] text-white dark:bg-[#60A5FA] dark:text-slate-950" 
                      : "hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400"}`}
          >
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');
  const root = document.documentElement;

  function setTheme(isDark: boolean) {
    if (!themeIcon) return;

    if (isDark) {
      root.classList.add('dark');
      root.style.colorScheme = 'dark';
      themeIcon.textContent = '🌙';
      window.localStorage.setItem('theme', 'dark');
    } else {
      root.classList.remove('dark');
      root.style.colorScheme = 'light';
      themeIcon.textContent = '☀️';
      window.localStorage.setItem('theme', 'light');
    }
  }

  const storedTheme = window.localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  setTheme(storedTheme ? storedTheme === 'dark' : prefersDark);

  themeToggle?.addEventListener('click', () => {
    const isDark = !root.classList.contains('dark');
    setTheme(isDark);
  });
</script>
