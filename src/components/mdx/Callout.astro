---
export interface Props {
  type?: "info" | "tip" | "tips" | "warning" | "danger" | "success";
  title?: string;
}

const {
  type = "info",
  title,
} = Astro.props;

const config = {
  info: {
    label: "Thông tin",
    icon: "ℹ️",
    tone: "border-sky-500/35 bg-sky-500/10 text-[var(--color-text)]",
  },
  tip: {
    label: "Mẹo",
    icon: "💡",
    tone: "border-emerald-500/35 bg-emerald-500/10 text-[var(--color-text)]",
  },
  tips: {
    label: "Mẹo",
    icon: "💡",
    tone: "border-emerald-500/35 bg-emerald-500/10 text-[var(--color-text)]",
  },
  warning: {
    label: "Lưu ý",
    icon: "⚠️",
    tone: "border-amber-500/35 bg-amber-500/10 text-[var(--color-text)]",
  },
  danger: {
    label: "Cảnh báo",
    icon: "⛔",
    tone: "border-rose-500/35 bg-rose-500/10 text-[var(--color-text)]",
  },
  success: {
    label: "Thành công",
    icon: "✅",
    tone: "border-teal-500/35 bg-teal-500/10 text-[var(--color-text)]",
  },
} as const;

const current = config[type] ?? config.info;
const heading = title ?? current.label;
---

<aside class={`my-6 rounded-[1.5rem] border p-4 md:p-5 ${current.tone}`}>
  <div class="flex items-start gap-3">
    <div class="mt-0.5 text-lg leading-none" aria-hidden="true">{current.icon}</div>
    <div class="min-w-0 flex-1">
      <p class="m-0 font-semibold tracking-tight text-[var(--color-text)]">{heading}</p>
      <div class="mt-2 text-sm leading-7 text-[var(--color-text-muted)] [&_a]:text-[var(--color-text)] [&_a]:underline [&_code]:rounded [&_code]:bg-black/10 [&_code]:px-1.5 [&_code]:py-0.5 dark:[&_code]:bg-white/10">
        <slot />
      </div>
    </div>
  </div>
</aside>
