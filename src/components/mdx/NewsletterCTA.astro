---
export interface Props {
  title?: string;
  description?: string;
  action?: string;
  placeholder?: string;
  buttonText?: string;
  note?: string;
}

const {
  title = "Nhận bài viết mới qua email",
  description = "Mỗi tuần một email ngắn về .NET, software architecture và web engineering.",
  action = "/newsletter",
  placeholder = "you@example.com",
  buttonText = "Đăng ký",
  note = "Không spam. Có thể hủy bất kỳ lúc nào.",
} = Astro.props;
---

<section class="my-10 rounded-3xl border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(124,77,255,0.08),rgba(0,104,121,0.12))] p-6 md:p-8">
  <div class="max-w-2xl">
    <p class="m-0 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">Newsletter</p>
    <h3 class="mt-2 text-2xl font-bold tracking-tight text-[var(--color-text)]">{title}</h3>
    <p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)] md:text-base">{description}</p>
  </div>

  <form action={action} method="get" class="mt-6 flex flex-col gap-3 sm:flex-row">
    <label class="sr-only" for="newsletter-email">Email</label>
    <input
      id="newsletter-email"
      name="email"
      type="email"
      inputmode="email"
      autocomplete="email"
      placeholder={placeholder}
      class="min-w-0 flex-1 rounded-2xl border border-[var(--color-outline)] bg-[var(--color-surface-raised)] px-4 py-3 text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-muted)] outline-none ring-0 transition focus:border-[var(--color-accent)]"
    />
    <button
      type="submit"
      class="action-button action-button--filled rounded-2xl"
    >
      {buttonText}
    </button>
  </form>

  <p class="mt-3 text-xs leading-6 text-[var(--color-text-muted)]">{note}</p>
</section>
