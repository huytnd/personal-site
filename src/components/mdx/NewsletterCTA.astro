---
export interface Props {
  title?: string;
  description?: string;
  action?: string;
  placeholder?: string;
  buttonText?: string;
  note?: string;
}

const {
  title = 'Nhận bài viết mới qua email',
  description = 'Mỗi tuần một email ngắn về .NET, software architecture và web engineering.',
  action = '/newsletter',
  placeholder = 'you@example.com',
  buttonText = 'Đăng ký',
  note = 'Không spam. Có thể hủy bất kỳ lúc nào.',
} = Astro.props;
---

<section class="my-10 rounded-3xl border border-cyan-400/20 bg-gradient-to-br from-cyan-500/10 via-sky-500/5 to-transparent p-6 md:p-8">
  <div class="max-w-2xl">
    <p class="m-0 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300/80">Newsletter</p>
    <h3 class="mt-2 text-2xl font-bold tracking-tight text-white">{title}</h3>
    <p class="mt-3 text-sm leading-7 text-zinc-300 md:text-base">{description}</p>
  </div>

  <form action={action} method="get" class="mt-6 flex flex-col gap-3 sm:flex-row">
    <label class="sr-only" for="newsletter-email">Email</label>
    <input
      id="newsletter-email"
      name="email"
      type="email"
      inputmode="email"
      autocomplete="email"
      placeholder={placeholder}
      class="min-w-0 flex-1 rounded-xl border border-white/10 bg-zinc-950/70 px-4 py-3 text-sm text-white placeholder:text-zinc-500 outline-none ring-0 transition focus:border-cyan-400/50"
    />
    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-300"
    >
      {buttonText}
    </button>
  </form>

  <p class="mt-3 text-xs leading-6 text-zinc-400">{note}</p>
</section>