---
export interface Props {
  title: string;
  description: string;
  href: string;
  buttonText?: string;
  eyebrow?: string;
}

const {
  title,
  description,
  href,
  buttonText = "Xem thêm",
  eyebrow = "Đề xuất tiếp theo",
} = Astro.props;
---

<section class="my-10 overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[linear-gradient(135deg,rgba(124,77,255,0.1),rgba(0,104,121,0.14))] p-6 shadow-[var(--shadow-raised)]">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="max-w-2xl">
      <p class="m-0 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">{eyebrow}</p>
      <h3 class="mt-2 text-xl font-bold tracking-tight text-[var(--color-text)] md:text-2xl">{title}</h3>
      <p class="mt-2 text-sm leading-7 text-[var(--color-text-muted)] md:text-base">{description}</p>
    </div>

    <div>
      <a href={href} class="action-button action-button--filled">
        {buttonText}
      </a>
    </div>
  </div>
</section>
