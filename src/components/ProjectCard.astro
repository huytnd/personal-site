---
import { hasRealUrl, type Project } from "@/data/projects";

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const number = String(index + 1).padStart(2, "0");
---

<article class="project-card group">
  <a href={`/projects/${project.slug}`} class="project-card-visual" aria-label={`View ${project.title} case study`}>
    <span class="font-mono text-7xl font-semibold tracking-tighter text-white/20 transition group-hover:text-white/30">
      {number}
    </span>
  </a>

  <div class="project-card-body">
    <div class="flex flex-wrap items-center gap-2">
      <span class="chip">{project.category}</span>
      {project.featured && <span class="chip chip--neutral">Featured</span>}
    </div>

    <h2 class="mt-5 text-2xl font-semibold tracking-tight text-[var(--color-text)]">
      <a href={`/projects/${project.slug}`} class="hover:text-[#0A2540] dark:hover:text-[#60A5FA]">
        {project.title}
      </a>
    </h2>

    <p class="mt-4 leading-7 text-[var(--color-text-muted)]">
      {project.description}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {project.stack.slice(0, 5).map((item) => (
        <span class="chip chip--neutral">{item}</span>
      ))}
    </div>

    <div class="mt-auto flex flex-wrap gap-3 pt-8">
      <a href={`/projects/${project.slug}`} class="action-button action-button--filled">
        View case study
        <span aria-hidden="true">-></span>
      </a>

      {hasRealUrl(project.sourceUrl) && (
        <a
          href={project.sourceUrl}
          target="_blank"
          rel="noreferrer"
          class="action-button action-button--text"
        >
          Source code
        </a>
      )}
    </div>
  </div>
</article>
