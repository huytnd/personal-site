---
interface Props {
  title: string;
  description: string;
  stack: string[];
  liveUrl?: string;
  sourceUrl?: string;
}

const { title, description, stack, liveUrl, sourceUrl } = Astro.props;
---

<article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
  <div class="flex items-start justify-between gap-4">
    <h2 class="text-xl font-semibold tracking-tight">
      {title}
    </h2>
  </div>

  <p class="mt-4 text-sm leading-7 text-gray-600">
    {description}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
        {item}
      </span>
    ))}
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    {liveUrl && (
      <a
        href={liveUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-lg bg-black px-4 py-2 text-sm font-medium text-white transition hover:opacity-90"
      >
        Live Demo
      </a>
    )}

    {sourceUrl && (
      <a
        href={sourceUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-900 transition hover:bg-gray-100"
      >
        Source Code
      </a>
    )}
  </div>
</article>