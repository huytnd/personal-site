---
interface Props {
  title: string;
  description: string;
  stack: string[];
  liveUrl?: string;
  sourceUrl?: string;
}

const { title, description, stack, liveUrl, sourceUrl } = Astro.props;
---

<article class="surface-card surface-card--interactive flex h-full flex-col">
  <div class="flex items-start justify-between gap-4">
    <h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)]">
      {title}
    </h2>
  </div>

  <p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
    {description}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="chip">{item}</span>
    ))}
  </div>

  <div class="mt-auto flex flex-wrap gap-3 pt-6">
    {liveUrl && (
      <a
        href={liveUrl}
        target="_blank"
        rel="noreferrer"
        class="action-button action-button--filled"
      >
        Live Demo
      </a>
    )}

    {sourceUrl && (
      <a
        href={sourceUrl}
        target="_blank"
        rel="noreferrer"
        class="action-button action-button--text"
      >
        Source Code
      </a>
    )}
  </div>
</article>
