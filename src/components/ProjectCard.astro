---
interface Props {
  title: string;
  description: string;
  stack: string[];
  liveUrl?: string;
  sourceUrl?: string;
}

const { title, description, stack, liveUrl, sourceUrl } = Astro.props;
---

<article class="rounded-[1.75rem] border border-slate-200/80 bg-white/82 p-6 shadow-[0_24px_50px_-40px_rgba(15,23,42,0.85)] backdrop-blur-sm transition hover:-translate-y-1 hover:shadow-[0_30px_60px_-38px_rgba(15,23,42,0.8)]">
  <div class="flex items-start justify-between gap-4">
    <h2 class="text-xl font-semibold tracking-tight text-slate-950">
      {title}
    </h2>
  </div>

  <p class="mt-4 text-sm leading-7 text-slate-600">
    {description}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded-full bg-teal-50 px-3 py-1 text-xs font-medium text-teal-800">
        {item}
      </span>
    ))}
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    {liveUrl && (
      <a
        href={liveUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full bg-slate-950 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800"
      >
        Live Demo
      </a>
    )}

    {sourceUrl && (
      <a
        href={sourceUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-50"
      >
        Source Code
      </a>
    )}
  </div>
</article>
