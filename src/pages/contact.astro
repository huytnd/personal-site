---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
  <section class="max-w-3xl py-4">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Contact</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">Let’s talk about backend engineering, shipping, or collaboration.</h1>
    <p class="mt-6 text-lg leading-8 text-slate-600">
      You can reach me through the channels below. Keep it direct and practical.
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <a href="mailto:hello@huytnd.io.vn" class="rounded-[1.5rem] border border-slate-200/80 bg-white/80 p-5 transition hover:-translate-y-1 hover:bg-white">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Email</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">hello@huytnd.io.vn</p>
      </a>
      <a href="https://github.com/huytnd" target="_blank" rel="noreferrer" class="rounded-[1.5rem] border border-slate-200/80 bg-white/80 p-5 transition hover:-translate-y-1 hover:bg-white">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">GitHub</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">github.com/huytnd</p>
      </a>
    </div>
  </section>
</BaseLayout>
