---
import BaseLayout from "../layouts/BaseLayout.astro";

const contacts = [
  {
    href: "mailto:hello@huytnd.io.vn",
    value: "hello@huytnd.io.vn",
    srLabel: "Email",
    icon: "mail",
  },
  {
    href: "https://github.com/huytnd",
    value: "github.com/huytnd",
    srLabel: "GitHub",
    icon: "github",
  },
  {
    href: "https://linkedin.com/in/huytnd",
    value: "linkedin.com/in/huytnd",
    srLabel: "LinkedIn",
    icon: "linkedin",
  },
];
---

<BaseLayout title="About">
  <section class="py-4">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="max-w-4xl">
        <p class="section-kicker">About</p>
        <h1 class="page-title text-4xl md:text-5xl xl:text-6xl">
          Backend-focused, delivery-oriented, and infrastructure-aware.
        </h1>
        <p class="page-copy max-w-3xl">
          I work across backend systems, fullstack delivery, and pragmatic deployment workflows.
          I care about readable code, stable releases, and making the operational side of software feel less fragile.
          I write about deployment notes, backend implementation details, and lessons learned from building and shipping software on my
          <a href="/blog" class="font-semibold text-[var(--color-text)] hover:underline"> blog</a>.
        </p>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="surface-card">
            <p class="eyebrow-label">What I build</p>
            <p class="mt-3 text-base leading-7 text-[var(--color-text-muted)]">
              APIs, internal tools, deployment-friendly apps, and portfolio projects with explicit engineering tradeoffs.
            </p>
          </div>
          <div class="surface-card">
            <p class="eyebrow-label">What I write about</p>
            <p class="mt-3 text-base leading-7 text-[var(--color-text-muted)]">
              Deployment notes, backend implementation details, and practical lessons from shipping software.
            </p>
          </div>
        </div>
      </div>

      <aside class="portrait-shell">
        <img
          src="/profile-photo.jpg"
          alt="Portrait of Huy Tran"
          class="portrait-image"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="portrait-placeholder" style="display: none;">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">Portrait Slot</p>
            <p class="mt-3 max-w-xs text-2xl font-semibold tracking-tight">Add `public/profile-photo.jpg` to show your photo here.</p>
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-14 border-t pt-10" style="border-color: var(--color-border);">
      <p class="section-kicker">Contact</p>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          contacts.map((contact) => (
            <a
              href={contact.href}
              target={contact.href.startsWith("http") ? "_blank" : undefined}
              rel={contact.href.startsWith("http") ? "noreferrer" : undefined}
              class="surface-card surface-card--interactive"
            >
              <div class="flex items-center gap-4">
                <span
                  class:list={[
                    "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-white shadow-lg shadow-black/10",
                    contact.icon === "linkedin"
                      ? "bg-[#0A66C2]"
                      : contact.icon === "mail"
                        ? "bg-[var(--color-accent)]"
                        : "bg-[var(--color-primary-strong)]",
                  ]}
                >
                  <span class="sr-only">{contact.srLabel}</span>
                  {
                    contact.icon === "mail" ? (
                      <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
                        <path d="M4 7.5 12 13l8-5.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"></path>
                        <rect x="3.25" y="5.25" width="17.5" height="13.5" rx="2.5" stroke="currentColor" stroke-width="1.8"></rect>
                      </svg>
                    ) : contact.icon === "linkedin" ? (
                      <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                        <path d="M5.37 3.5a1.87 1.87 0 1 1 0 3.74 1.87 1.87 0 0 1 0-3.74ZM3.75 8.9h3.24v10.85H3.75V8.9Zm5.27 0h3.1v1.48h.04c.43-.82 1.48-1.69 3.04-1.69 3.24 0 3.84 2.13 3.84 4.91v6.15H15.8v-5.45c0-1.3-.02-2.98-1.81-2.98-1.82 0-2.1 1.42-2.1 2.89v5.54H8.65V8.9h.37Z"></path>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                        <path d="M12 .5C5.65.5.5 5.8.5 12.33c0 5.23 3.3 9.67 7.88 11.24.58.11.79-.26.79-.58 0-.29-.01-1.05-.02-2.07-3.2.71-3.88-1.58-3.88-1.58-.52-1.37-1.28-1.73-1.28-1.73-1.05-.74.08-.73.08-.73 1.16.08 1.77 1.22 1.77 1.22 1.03 1.82 2.71 1.29 3.37.98.1-.77.4-1.29.72-1.59-2.55-.3-5.23-1.31-5.23-5.84 0-1.29.45-2.34 1.19-3.17-.12-.3-.52-1.52.11-3.17 0 0 .97-.32 3.19 1.21a10.8 10.8 0 0 1 5.8 0c2.21-1.53 3.18-1.21 3.18-1.21.63 1.65.23 2.87.11 3.17.74.83 1.19 1.88 1.19 3.17 0 4.54-2.68 5.54-5.24 5.83.41.36.77 1.07.77 2.16 0 1.56-.01 2.82-.01 3.2 0 .32.21.7.8.58 4.57-1.57 7.87-6.01 7.87-11.24C23.5 5.8 18.35.5 12 .5Z"></path>
                      </svg>
                    )
                  }
                </span>
                <div>
                  <p class="eyebrow-label">{contact.srLabel}</p>
                  <p class="mt-1 text-base font-semibold text-[var(--color-text)]">{contact.value}</p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
