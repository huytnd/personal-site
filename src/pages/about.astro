---
import BaseLayout from "../layouts/BaseLayout.astro";

const contacts = [
  {
    href: "mailto:hello@huytnd.io.vn",
    value: "hello@huytnd.io.vn",
    srLabel: "Email",
    icon: "mail",
  },
  {
    href: "https://github.com/huytnd",
    value: "github.com/huytnd",
    srLabel: "GitHub",
    icon: "github",
  },
  {
    href: "https://linkedin.com/in/huytnd",
    value: "linkedin.com/in/huytnd",
    srLabel: "LinkedIn",
    icon: "linkedin",
  },
];

const profileStats = [
  {
    label: "Experience",
    value: "10+ years",
    description: "Shipping production systems with practical engineering tradeoffs.",
  },
  {
    label: "Location",
    value: "Ho Chi Minh City",
    description: "Working with teams across backend, cloud, and product delivery.",
  },
  {
    label: "Focus",
    value: ".NET + Cloud",
    description: "APIs, distributed systems, deployment, and observable services.",
  },
];

const workPrinciples = [
  {
    title: "Architecture with a reason",
    description:
      "I prefer simple boundaries, explicit tradeoffs, and systems that can evolve without surprising the team later.",
  },
  {
    title: "Delivery that survives reality",
    description:
      "A feature is not finished when it runs locally. It should build, deploy, roll back, and explain itself under pressure.",
  },
  {
    title: "Observability by default",
    description:
      "Logs, metrics, and operational signals are part of the product experience, especially for backend-heavy systems.",
  },
  {
    title: "Maintainability over ceremony",
    description:
      "Readable code, boring infrastructure, and clear ownership matter more to me than cleverness for its own sake.",
  },
];

const careItems = [
  "Readable code with clear naming and honest abstractions",
  "Stable releases backed by repeatable build and deployment paths",
  "Pragmatic infrastructure that reduces operational friction",
  "Technical writing that turns hard-won lessons into reusable context",
];
---

<BaseLayout
  title="About"
  description="About Huy Tran, a backend-focused software engineer working across .NET, cloud systems, deployment workflows, and production-minded software delivery."
>
  <section class="about-hero">
    <div class="about-hero-copy">
      <p class="section-kicker">About</p>
      <h1 class="page-title mt-3 text-5xl text-slate-950 dark:text-white md:text-6xl xl:text-7xl">
        Backend-focused, delivery-oriented, and infrastructure-aware.
      </h1>

      <p class="page-copy max-w-4xl">
        I work across backend systems, fullstack delivery, and pragmatic deployment workflows.
        I care about readable code, stable releases, and making the operational side of software feel less fragile.
        I document those lessons through
        <a href="/blog" class="font-semibold text-[var(--color-text)] underline underline-offset-4">technical writing</a>
        and turn them into
        <a href="/projects" class="font-semibold text-[var(--color-text)] underline underline-offset-4">portfolio projects</a>
        that show the tradeoffs behind the build.
      </p>

      <div class="mt-9 flex flex-wrap gap-3">
        <a href="mailto:hello@huytnd.io.vn" class="action-button action-button--filled">
          Contact me
          <span aria-hidden="true">-></span>
        </a>
        <a href="/projects" class="action-button action-button--tonal">
          View projects
          <span aria-hidden="true">-></span>
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        <span class="chip">Backend systems</span>
        <span class="chip chip--neutral">Deployment</span>
        <span class="chip chip--neutral">Observability</span>
        <span class="chip chip--neutral">Cloud architecture</span>
      </div>
    </div>

    <aside class="portrait-shell">
      <img
        src="/profile-photo.jpg"
        alt="Portrait of Huy Tran"
        class="portrait-image"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="portrait-placeholder" style="display: none;">
        <div>
          <p class="eyebrow-label text-white/70">Portrait Slot</p>
          <p class="mt-3 max-w-xs text-2xl font-semibold tracking-tight text-white">
            Add `public/profile-photo.jpg` to show your photo here.
          </p>
        </div>
      </div>
    </aside>
  </section>

  <section class="about-section">
    <div class="about-profile-grid">
      {
        profileStats.map((item) => (
          <article class="about-profile-card">
            <p class="eyebrow-label">{item.label}</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[#0A2540] dark:text-[#60A5FA]">
              {item.value}
            </h2>
            <p class="mt-3 text-sm leading-6 text-[var(--color-text-muted)]">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="about-section">
    <div class="mb-8 max-w-3xl">
      <p class="section-kicker">How I work</p>
      <h2 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-5xl">
        Clear systems, calm releases, fewer surprises.
      </h2>
      <p class="page-copy">
        My favorite engineering work sits where product delivery, backend design, and operations meet.
        The goal is not only to build software that works, but software that remains understandable after it ships.
      </p>
    </div>

    <div class="about-story-grid">
      {
        workPrinciples.map((item, index) => (
          <article class="surface-card">
            <span class="font-mono text-sm font-semibold text-[#0A2540] dark:text-[#60A5FA]">
              0{index + 1}
            </span>
            <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--color-text)]">
              {item.title}
            </h3>
            <p class="mt-4 leading-7 text-[var(--color-text-muted)]">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="about-section">
    <div class="about-care-panel">
      <div>
        <p class="section-kicker">What I care about</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Practical engineering with operational empathy.
        </h2>
        <p class="page-copy max-w-3xl">
          I like systems that a team can reason about quickly: clear contracts, useful signals,
          predictable releases, and documentation that helps the next person move faster.
        </p>
      </div>

      <ul class="about-care-list">
        {
          careItems.map((item) => (
            <li>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
                  <path d="m5 12 4 4L19 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="about-section">
    <div class="about-contact-header">
      <div>
        <p class="section-kicker">Contact</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Let’s talk about the next system to ship.
        </h2>
      </div>
      <p class="page-copy max-w-2xl">
        I am open to conversations around backend engineering, cloud-native systems,
        deployment workflows, and production-minded fullstack projects.
      </p>
    </div>

    <div class="about-contact-grid">
      {
        contacts.map((contact) => (
          <a
            href={contact.href}
            target={contact.href.startsWith("http") ? "_blank" : undefined}
            rel={contact.href.startsWith("http") ? "noreferrer" : undefined}
            class="about-contact-card"
          >
            <span
              class:list={[
                "about-contact-icon",
                contact.icon === "linkedin"
                  ? "bg-[#0A66C2]"
                  : contact.icon === "mail"
                    ? "bg-[var(--color-accent)]"
                    : "bg-[var(--color-primary-strong)]",
              ]}
            >
              <span class="sr-only">{contact.srLabel}</span>
              {
                contact.icon === "mail" ? (
                  <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
                    <path d="M4 7.5 12 13l8-5.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"></path>
                    <rect x="3.25" y="5.25" width="17.5" height="13.5" rx="2.5" stroke="currentColor" stroke-width="1.8"></rect>
                  </svg>
                ) : contact.icon === "linkedin" ? (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                    <path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19ZM8.339 10.339H5.667V18.333H8.339V10.339ZM7.003 6.071A1.55 1.55 0 0 0 5.45 7.625c0 .858.694 1.554 1.553 1.554h.018a1.554 1.554 0 1 0-.018-3.108ZM18.333 13.467c0-2.699-1.439-3.955-3.359-3.955-1.548 0-2.241.852-2.628 1.451v-1.624H9.675c.035 1.076 0 8.994 0 8.994h2.671V13.87c0-.238.017-.477.087-.648.188-.476.616-.969 1.336-.969.943 0 1.321.73 1.321 1.801v4.279h2.672l.001-4.866Z"></path>
                  </svg>
                ) : (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.699-2.782.605-3.369-1.343-3.369-1.343-.455-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.071 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.091-.647.349-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.56 9.56 0 0 1 2.504.337c1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.202 2.398.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.921.678 1.857 0 1.339-.012 2.419-.012 2.748 0 .268.18.58.688.481A10.019 10.019 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z"></path>
                  </svg>
                )
              }
            </span>
            <span>
              <span class="eyebrow-label">{contact.srLabel}</span>
              <span class="mt-2 block text-base font-semibold text-[var(--color-text)]">
                {contact.value}
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
