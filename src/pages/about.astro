---
import BaseLayout from "../layouts/BaseLayout.astro";
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";

const portraitCandidates = [
  "/profile-photo.jpg",
  "/profile-photo.jpeg",
  "/profile-photo.png",
  "/profile-photo.webp",
];

const portraitSrc =
  portraitCandidates.find((src) =>
    existsSync(fileURLToPath(new URL(`../../public${src}`, import.meta.url)))
  ) ?? null;
---

<BaseLayout title="About">
  <section class="py-4">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">About</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 md:text-5xl xl:text-6xl">Backend-focused, delivery-oriented, and infrastructure-aware.</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
          I work across backend systems, fullstack product delivery, and pragmatic deployment workflows.
          I care about readable code, stable releases, and making the operational side of software feel less fragile.
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/80 p-5">
            <h2 class="text-lg font-semibold text-slate-950">What I build</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">APIs, internal tools, deployment-friendly apps, and portfolio projects that emphasize clear engineering tradeoffs.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/80 p-5">
            <h2 class="text-lg font-semibold text-slate-950">What I write about</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">Deployment notes, backend implementation details, and lessons learned from building and shipping software.</p>
          </div>
        </div>
      </div>

      <aside class="portrait-shell">
        {
          portraitSrc ? (
            <img
              src={portraitSrc}
              alt="Portrait of Huy Tran"
              class="portrait-image"
            />
          ) : (
            <div class="portrait-placeholder">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">Portrait Slot</p>
                <p class="mt-3 max-w-xs text-2xl font-semibold tracking-tight">Add `public/profile-photo.jpg` to show your photo here.</p>
              </div>
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>
