---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = [
	{
		title: "Fullstack Task Manager",
		description:
			"A production-style fullstack application with ASP.NET Core, PostgreSQL, and Docker.",
	},
	{
		title: "URL Shortener API",
		description:
			"A backend-focused service with clean API design, analytics, and containerized deployment.",
	},
	{
		title: "Personal Portfolio Platform",
		description:
			"A self-hosted Astro website and blog deployed on a VPS with Dokploy.",
	},
];
---

<BaseLayout title="Home">
	<section class="py-16">
		<p
			class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">
			Backend / Cloud Engineer
		</p>

		<h1 class="mt-4 text-5xl font-bold tracking-tight">Huy Tran</h1>

		<p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">
			I build production-ready web applications with .NET, Docker, and
			modern frontend tools, while documenting deployment and engineering
			lessons through a personal blog.
		</p>

		<div class="mt-8 flex flex-wrap gap-4">
			<a
				href="/projects"
				class="rounded-lg bg-black px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
			>
				View Projects
			</a>

			<a
				href="/blog"
				class="rounded-lg border border-gray-300 bg-white px-5 py-3 text-sm font-medium text-gray-900 transition hover:bg-gray-100"
			>
				Read Blog
			</a>
		</div>
	</section>
	<section class="border-t border-gray-200 py-16">
		<div class="flex items-end justify-between gap-4">
			<div>
				<p
					class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500"
				>
					Featured Work
				</p>
				<h2 class="mt-3 text-3xl font-bold tracking-tight">
					A few things I’m building
				</h2>
			</div>

			<a
				href="/projects"
				class="text-sm font-medium text-gray-700 transition hover:text-black"
			>
				View all projects →
			</a>
		</div>

		<div class="mt-8 grid gap-6 md:grid-cols-3">
			{
				featuredProjects.map((project) => (
					<article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
						<h3 class="text-lg font-semibold">{project.title}</h3>
						<p class="mt-3 text-sm leading-7 text-gray-600">
							{project.description}
						</p>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
