---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = [
  {
    title: "Fullstack Task Manager",
    description:
      "A production-style fullstack application with ASP.NET Core, PostgreSQL, and Docker.",
    meta: "System design, auth flows, delivery workflow",
  },
  {
    title: "URL Shortener API",
    description:
      "A backend-focused service with clean API design, analytics, and containerized deployment.",
    meta: "API design, metrics, persistence",
  },
  {
    title: "Personal Portfolio Platform",
    description:
      "A self-hosted Astro website and blog deployed on a VPS with Dokploy.",
    meta: "Design system, content architecture, deployment",
  },
];

const highlights = [
  { value: "4+", label: "Core delivery areas across backend, infra, and frontend" },
  { value: "Remote", label: "Working from Ho Chi Minh City with async-friendly workflows" },
  { value: "Build", label: "Calm releases, practical architecture, and operational clarity" },
];
---

<BaseLayout title="Welcome">
  <section class="grid gap-8 py-4 lg:grid-cols-[1.1fr_0.9fr] lg:items-end lg:py-8">
    <div>
      <p class="section-kicker">Backend / Cloud Engineer</p>
      <h1 class="page-title max-w-4xl text-5xl leading-[1.02] md:text-6xl xl:text-[4.5rem]">
        Production-ready software shaped with Material clarity.
      </h1>
      <p class="page-copy max-w-2xl text-[1.08rem]">
        I build backend-first web applications with dependable delivery pipelines,
        then document the architectural and deployment decisions behind them.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/projects" class="action-button action-button--filled">View Projects</a>
        <a href="/blog" class="action-button action-button--tonal">Read Blog</a>
      </div>

      <div class="hero-metrics">
        {
          highlights.map((item) => (
            <div class="hero-metric">
              <p class="hero-metric__value">{item.value}</p>
              <p class="hero-metric__label">{item.label}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hero-panel">
      <div class="relative z-10">
        <span class="chip">Current Focus</span>
        <p class="mt-5 max-w-md text-[1.9rem] font-semibold leading-tight tracking-tight text-[var(--color-text)] md:text-[2.35rem]">
          Durable product delivery with explicit architecture, measurable stability, and lower operational drag.
        </p>

        <div class="mt-6 grid gap-4">
          <div class="surface-subtle">
            <p class="eyebrow-label">Primary stack</p>
            <p class="mt-2 text-base font-semibold leading-7 text-[var(--color-text)]">
              .NET, PostgreSQL, Docker, Astro, and deployment workflows that stay readable.
            </p>
          </div>

          <div class="surface-subtle">
            <p class="eyebrow-label">Delivery lens</p>
            <p class="mt-2 text-base font-semibold leading-7 text-[var(--color-text)]">
              Stable releases, maintainable systems, and interfaces that communicate state clearly.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t pt-16" style="border-color: var(--color-border);">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-kicker">Featured Work</p>
        <h2 class="page-title text-3xl md:text-4xl">Selected builds with real delivery constraints</h2>
      </div>

      <a href="/projects" class="action-button action-button--text">Browse all projects</a>
    </div>

    <div class="mt-8 portfolio-grid">
      {
        featuredProjects.map((project) => (
          <article class="surface-card surface-card--interactive flex h-full flex-col">
            <span class="chip chip--neutral w-fit">Project</span>
            <h3 class="mt-5 text-xl font-semibold text-[var(--color-text)] md:text-2xl">{project.title}</h3>
            <p class="mt-3 text-sm uppercase tracking-[0.16em] text-[var(--color-text-muted)]">{project.meta}</p>
            <p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)] md:text-base">
              {project.description}
            </p>
            <div class="mt-auto pt-6">
              <a href="/projects" class="card-link">Explore project details</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
