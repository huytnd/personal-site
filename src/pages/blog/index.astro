---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/blog/Pagination.astro";
import PostCard from "@/components/blog/PostCard.astro";
import TaxonomyPills from "@/components/blog/TaxonomyPills.astro";
import {
  BLOG_PAGE_SIZE,
  formatBlogDate,
  getAllCategories,
  getAllPosts,
  getAllTags,
  getArchiveUrl,
  getBlogIndexPageUrl,
  getBlogPostUrl,
  getPaginationLinks,
} from "@/lib/blog";

const posts = await getAllPosts();
const categories = await getAllCategories();
const tags = await getAllTags();

const pagePosts = posts.slice(0, BLOG_PAGE_SIZE);
const featuredPost = pagePosts.find((post) => post.data.featured) ?? pagePosts[0];
const latestPosts = featuredPost
  ? pagePosts.filter((post) => post.id !== featuredPost.id)
  : pagePosts;
const totalPages = Math.ceil(posts.length / BLOG_PAGE_SIZE);
const pagination = getPaginationLinks(1, totalPages, getBlogIndexPageUrl);
---

<BaseLayout
  title="Blog"
  description="Technical notes about backend engineering, deployment, Astro, cloud learning, and lessons from building production-minded projects."
>
  <section class="blog-hero">
    <div class="max-w-4xl">
      <p class="section-kicker">Writing</p>
      <h1 class="page-title mt-3 text-5xl text-slate-950 dark:text-white md:text-6xl xl:text-7xl">
        Engineering notes from the build side.
      </h1>
      <p class="page-copy max-w-3xl">
        Practical writing about backend architecture, deployment workflows, Astro, cloud systems,
        and the small decisions that make software easier to ship and operate.
      </p>
    </div>

    <div class="blog-summary-grid">
      <div>
        <p class="eyebrow-label">Articles</p>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-[#0A2540] dark:text-[#60A5FA]">
          {posts.length}
        </p>
      </div>
      <div>
        <p class="eyebrow-label">Topics</p>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-[#0A2540] dark:text-[#60A5FA]">
          {categories.length}
        </p>
      </div>
      <div>
        <p class="eyebrow-label">Browse</p>
        <div class="mt-3 flex flex-wrap gap-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
          <a href={getArchiveUrl()} class="blog-text-link">
            Archive
            <span aria-hidden="true">-></span>
          </a>
          <a href="/rss.xml" class="blog-text-link">
            RSS feed
            <span aria-hidden="true">-></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="blog-section mt-12">
        <TaxonomyPills
          categories={categories}
          tagItems={tags.slice(0, 8)}
        />
      </section>
    )
  }

  {
    featuredPost && (
      <section class="blog-section mt-16">
        <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="section-kicker">Featured</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-4xl">
              Start here
            </h2>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Page 1 of {Math.max(totalPages, 1)}
          </p>
        </div>

        <article class="featured-post-card">
          <a
            href={getBlogPostUrl(featuredPost)}
            class="featured-post-media group"
            aria-label={`Read ${featuredPost.data.title}`}
          >
            {featuredPost.data.coverImage ? (
              <Image
                src={featuredPost.data.coverImage}
                alt={featuredPost.data.coverAlt ?? featuredPost.data.title}
                widths={[640, 960, 1280]}
                sizes="(max-width: 1024px) 100vw, 44rem"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="featured-post-placeholder">
                <span class="font-mono text-7xl tracking-tighter text-white/20">01</span>
              </div>
            )}
          </a>

          <div class="flex min-w-0 flex-col p-6 md:p-8 lg:p-10">
            <div class="flex flex-wrap items-center gap-2">
              <TaxonomyPills category={featuredPost.data.category} />
              <span class="text-sm text-slate-500 dark:text-slate-400">
                {formatBlogDate(featuredPost.data.publishedDate)}
              </span>
            </div>

            <h3 class="mt-5 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-4xl">
              <a
                href={getBlogPostUrl(featuredPost)}
                class="hover:text-[#0A2540] dark:hover:text-[#60A5FA]"
              >
                {featuredPost.data.title}
              </a>
            </h3>

            <p class="mt-5 text-base leading-8 text-slate-600 dark:text-slate-300 md:text-lg">
              {featuredPost.data.description}
            </p>

            <TaxonomyPills className="mt-6" tags={featuredPost.data.tags} />

            <div class="mt-8">
              <a
                href={getBlogPostUrl(featuredPost)}
                class="action-button action-button--filled"
              >
                Read article
                <span aria-hidden="true">-></span>
              </a>
            </div>
          </div>
        </article>
      </section>
    )
  }

  {
    latestPosts.length > 0 && (
      <section class="blog-section mt-20">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="section-kicker">Latest</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-4xl">
              More articles
            </h2>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Showing {pagePosts.length} of {posts.length}
          </p>
        </div>

        <div class="blog-post-grid">
          {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )
  }

  <section class="blog-section mt-16">
    <Pagination
      currentPage={1}
      lastPage={Math.max(totalPages, 1)}
      firstUrl={pagination.first}
      prevUrl={pagination.prev}
      nextUrl={pagination.next}
      lastUrl={pagination.last}
    />
  </section>
</BaseLayout>
