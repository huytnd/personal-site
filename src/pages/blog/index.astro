---
import BaseLayout from "../../layouts/BaseLayout.astro";

type BlogModule = {
  frontmatter: {
    title: string;
    description: string;
    publishedDate: string | Date;
    updatedDate?: string | Date;
    category?: string;
    tags?: string[];
  };
};

const blogModules = import.meta.glob("../../content/blog/**/*.{md,mdx}", {
  eager: true,
}) as Record<string, BlogModule>;

const resolveCategory = (postId: string, frontmatterCategory?: string) =>
  frontmatterCategory?.trim() ||
  (postId.includes("/") ? postId.split("/")[0] : "uncategorized");

const posts = Object.entries(blogModules)
  .map(([filePath, module]) => {
    const relativePath = filePath
      .replace("../../content/blog/", "")
      .replace(/\.(md|mdx)$/, "");

    return {
      id: relativePath,
      data: {
        ...module.frontmatter,
        publishedDate: new Date(module.frontmatter.publishedDate),
        updatedDate: module.frontmatter.updatedDate
          ? new Date(module.frontmatter.updatedDate)
          : undefined,
      },
    };
  })
  .sort(
    (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime(),
  );

const formatCategory = (category: string) =>
  category
    .split(/[-_]/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const postsByCategory = posts.reduce<
  Array<{
    category: string;
    label: string;
    posts: Array<(typeof posts)[number]>;
  }>
>((groups, post) => {
  const category = resolveCategory(post.id, post.data.category);
  const existingGroup = groups.find((group) => group.category === category);

  if (existingGroup) {
    existingGroup.posts.push(post);
    return groups;
  }

  groups.push({
    category,
    label: formatCategory(category),
    posts: [post],
  });

  return groups;
}, []);
---

<BaseLayout title="Blog">
  <section>
    <p class="section-kicker">Writing</p>
    <h1 class="page-title text-4xl md:text-5xl">Blog</h1>
    <p class="page-copy max-w-2xl">
      Notes about backend engineering, deployment, cloud learning, and lessons from building projects.
    </p>
  </section>

  <section class="mt-12 space-y-12">
    {
      postsByCategory.map((group) => (
        <div>
          <div class="mb-5 flex flex-wrap items-center gap-3">
            <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)]">
              {group.label}
            </h2>
            <span class="chip chip--neutral">
              {group.posts.length} post{group.posts.length > 1 ? "s" : ""}
            </span>
          </div>

          <div class="space-y-6">
            {group.posts.map((post) => (
              <article class="surface-card surface-card--interactive">
                <div class="flex flex-wrap gap-2">
                  {post.data.tags?.map((tag) => (
                    <span class="chip">#{tag}</span>
                  ))}
                </div>

                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--color-text)]">
                  <a href={`/blog/${post.id}`} class="hover:underline">
                    {post.data.title}
                  </a>
                </h3>

                <p class="mt-3 text-sm text-[var(--color-text-muted)]">
                  {post.data.publishedDate.toDateString()}
                </p>

                <p class="mt-4 leading-7 text-[var(--color-text-muted)]">
                  {post.data.description}
                </p>

                <div class="mt-5">
                  <a href={`/blog/${post.id}`} class="action-button action-button--tonal">
                    Read article
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </section>
</BaseLayout>
