---
import BaseLayout from "../../layouts/BaseLayout.astro";

type BlogModule = {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string | Date;
    category?: string;
    tags?: string[];
  };
};

const blogModules = import.meta.glob("../../content/blog/**/*.{md,mdx}", {
  eager: true,
}) as Record<string, BlogModule>;

const posts = Object.entries(blogModules)
  .map(([filePath, module]) => {
    const relativePath = filePath
      .replace("../../content/blog/", "")
      .replace(/\.(md|mdx)$/, "");

    return {
      id: relativePath,
      data: {
        ...module.frontmatter,
        pubDate: new Date(module.frontmatter.pubDate),
      },
    };
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatCategory = (category: string) =>
  category
    .split(/[-_]/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const postsByCategory = posts.reduce<
  Array<{
    category: string;
    label: string;
    posts: Array<(typeof posts)[number]>;
  }>
>((groups, post) => {
  const category = post.id.includes("/") ? post.id.split("/")[0] : "uncategorized";
  const existingGroup = groups.find((group) => group.category === category);

  if (existingGroup) {
    existingGroup.posts.push(post);
    return groups;
  }

  groups.push({
    category,
    label: formatCategory(category),
    posts: [post],
  });

  return groups;
}, []);
---

<BaseLayout title="Blog">
    <section>
        <p
            class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500"
        >
            Writing
        </p>

        <h1 class="mt-4 text-4xl font-bold tracking-tight">Blog</h1>

        <p class="mt-4 max-w-2xl text-lg leading-8 text-gray-600">
            Notes about backend engineering, deployment, cloud learning, and lessons from building projects.
        </p>
    </section>

    <section class="mt-12 space-y-12">
        {
            postsByCategory.map((group) => (
                <div>
                    <div class="mb-5 flex items-center gap-3">
                        <h2 class="text-2xl font-semibold tracking-tight">
                            {group.label}
                        </h2>
                        <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium uppercase tracking-[0.16em] text-gray-600">
                            {group.posts.length} post{group.posts.length > 1 ? "s" : ""}
                        </span>
                    </div>

                    <div class="space-y-6">
                        {group.posts.map((post) => (
                            <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
                                <div class="flex flex-wrap gap-2">
                                    {post.data.tags?.map((tag) => (
                                        <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
                                            #{tag}
                                        </span>
                                    ))}
                                </div>

                                <h3 class="mt-4 text-2xl font-semibold tracking-tight">
                                    <a href={`/blog/${post.id}`} class="hover:underline">
                                        {post.data.title}
                                    </a>
                                </h3>

                                <p class="mt-3 text-sm text-gray-500">
                                    {post.data.pubDate.toDateString()}
                                </p>

                                <p class="mt-4 leading-7 text-gray-600">
                                    {post.data.description}
                                </p>

                                <div class="mt-5">
                                    <a
                                        href={`/blog/${post.id}`}
                                        class="text-sm font-medium text-gray-800 hover:text-black"
                                    >
                                        Read article →
                                    </a>
                                </div>
                            </article>
                        ))}
                    </div>
                </div>
            ))
        }
    </section>
</BaseLayout>
