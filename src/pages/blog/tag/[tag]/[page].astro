---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Pagination from "@/components/blog/Pagination.astro";
import PostCard from "@/components/blog/PostCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  BLOG_PAGE_SIZE,
  getAllTags,
  getPaginationLinks,
  getPostsByTag,
  getTagPageUrl,
} from "@/lib/blog";

export const getStaticPaths = (async ({ paginate }) => {
  const tags = await getAllTags();
  const entries = await Promise.all(
    tags.map(async (tag) => {
      const posts = await getPostsByTag(tag.slug);

      return paginate(posts, {
        pageSize: BLOG_PAGE_SIZE,
        params: { tag: tag.slug },
        props: { tag },
      })
        .slice(1)
        .map((entry) => ({
          ...entry,
          params: {
            ...entry.params,
            page: `page-${entry.props.page.currentPage}`,
          },
        }));
    }),
  );

  return entries.flat();
}) satisfies GetStaticPaths;

const { page, tag } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const pagination = getPaginationLinks(
  page.currentPage,
  page.lastPage,
  (pageNumber) => getTagPageUrl(tag.slug, pageNumber),
);
---

<BaseLayout
  title={`#${tag.label} - Page ${page.currentPage}`}
  description={`Page ${page.currentPage} of the ${tag.label} tag archive.`}
>
  <section class="blog-hero">
    <div class="max-w-4xl">
      <a href={getTagPageUrl(tag.slug)} class="article-link">
        <span aria-hidden="true">&lt;-</span>
        Back to #{tag.label}
      </a>
      <p class="section-kicker mt-8">Tag</p>
      <h1 class="page-title mt-3 text-5xl text-slate-950 dark:text-white md:text-6xl">
        #{tag.label}, page {page.currentPage}
      </h1>
      <p class="page-copy max-w-3xl">
        Paginated tag results stay inside the blog namespace and reuse the same normalized slug behavior as the index and post metadata.
      </p>
    </div>

    <div class="blog-summary-grid">
      <div>
        <p class="eyebrow-label">Current page</p>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-[#0A2540] dark:text-[#60A5FA]">
          {page.currentPage}
        </p>
      </div>
      <div>
        <p class="eyebrow-label">Total pages</p>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-[#0A2540] dark:text-[#60A5FA]">
          {page.lastPage}
        </p>
      </div>
      <div>
        <p class="eyebrow-label">Posts</p>
        <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
          Showing {page.start + 1}-{page.end + 1} of {page.total} posts.
        </p>
      </div>
    </div>
  </section>

  <section class="blog-section mt-16">
    <div class="blog-post-grid">
      {page.data.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="blog-section mt-16">
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      firstUrl={pagination.first}
      prevUrl={pagination.prev}
      nextUrl={pagination.next}
      lastUrl={pagination.last}
    />
  </section>
</BaseLayout>
