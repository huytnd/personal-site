---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCover from '../../components/BlogCover.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post || post.data.draft) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);

// Route OG image động cho từng bài
const dynamicOgImage = `/open-graph/${post.slug}.png`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={dynamicOgImage}
  type="article"
  publishedDate={post.data.publishedDate.toISOString()}
  updatedDate={post.data.updatedDate?.toISOString()}
>
  <article>
    <h1>{post.data.title}</h1>

    <p>
      {post.data.publishedDate.toLocaleDateString('vi-VN')}
    </p>

    <BlogCover src={post.data.coverImage} alt={post.data.coverAlt} />

    <Content />
  </article>
</BaseLayout>
