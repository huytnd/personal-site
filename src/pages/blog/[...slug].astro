---
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";

type BlogModule = {
  Content: any;
  frontmatter: {
    title: string;
    description: string;
    publishedDate: string | Date;
    updatedDate?: string | Date;
    category?: string;
    tags?: string[];
  };
};

const blogModules = import.meta.glob("../../content/blog/**/*.{md,mdx}", {
  eager: true,
}) as Record<string, BlogModule>;

const resolveCategory = (postId: string, frontmatterCategory?: string) =>
  frontmatterCategory?.trim() ||
  (postId.includes("/") ? postId.split("/")[0] : "uncategorized");

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/blog/**/*.{md,mdx}", {
    eager: true,
  }) as Record<string, BlogModule>;

  return Object.entries(modules).map(([filePath]) => ({
    params: {
      slug: filePath
        .replace("../../content/blog/", "")
        .replace(/\.(md|mdx)$/, ""),
    },
  }));
}

const slugParam = Astro.params.slug;
const postId = Array.isArray(slugParam) ? slugParam.join("/") : slugParam;
const posts = Object.entries(blogModules).map(([filePath, module]) => {
  const relativePath = filePath
    .replace("../../content/blog/", "")
    .replace(/\.(md|mdx)$/, "");

  return {
    id: relativePath,
    category: resolveCategory(relativePath, module.frontmatter.category),
    Content: module.Content,
    data: {
      ...module.frontmatter,
      publishedDate: new Date(module.frontmatter.publishedDate),
      updatedDate: module.frontmatter.updatedDate
        ? new Date(module.frontmatter.updatedDate)
        : undefined,
    },
  };
});

if (!postId) {
  throw new Error("Post slug is required");
}

const post = posts.find((entry) => entry.id === postId);

if (!post) {
  throw new Error(`Post not found: ${postId}`);
}

const { Content } = post;
---

<BlogPostLayout frontmatter={post.data} category={post.category}>
  <Content />
</BlogPostLayout>
